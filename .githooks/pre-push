#!/bin/bash
# codex pre-push hook — review diff with codex before pushing to remote.
#
# Install:           make hooks-install  (sets core.hooksPath=.githooks)
# Bypass one push:   git push --no-verify
# Bypass via env:    SKIP_CODEX_REVIEW=1 git push
# Bypass via msg:    include [skip-codex] or [wip] in a commit message in the push range
#
# Behavior:
#   - Only runs on `git push`. Never runs on commit/stash/rebase.
#   - Reviews only the diff being pushed (remote_sha..local_sha) for .swift and *.md files.
#   - Blocks push (exit 1) when codex reports any [P1] issue.
#   - Caches passed shas under .git/codex-reviewed-<sha> to avoid re-review on retry.
#   - Codex binary missing, timeout, or big diff → warn and allow push.

set -u

REMOTE="$1"
URL="$2"

ZERO="0000000000000000000000000000000000000000"
TIMEOUT_SEC=300
BIG_DIFF_LINES=5000

# Resolve actual git dir — in a worktree `.git` is a file, not a directory,
# so `.git/codex-reviewed-<sha>` would fail with "Not a directory".
GIT_DIR=$(git rev-parse --git-dir 2>/dev/null || echo ".git")

# ── global env bypass ─────────────────────────────────────────────
if [ "${SKIP_CODEX_REVIEW:-}" = "1" ]; then
  echo "codex: SKIP_CODEX_REVIEW=1, skipping review" >&2
  exit 0
fi

# ── pick a timeout command (macOS stock has none; brew coreutils provides both) ──
if command -v timeout >/dev/null 2>&1; then
  TO="timeout $TIMEOUT_SEC"
elif command -v gtimeout >/dev/null 2>&1; then
  TO="gtimeout $TIMEOUT_SEC"
else
  TO=""
  echo "codex: no 'timeout' binary found; review may hang if codex stalls" >&2
fi

# ── read pre-push protocol from stdin ─────────────────────────────
while read -r local_ref local_sha remote_ref remote_sha; do
  # skip branch deletes
  [ "$local_sha" = "$ZERO" ] && continue

  # compute diff range
  if [ "$remote_sha" = "$ZERO" ]; then
    # new branch: diff against nearest ref on remote
    base=$(git rev-parse "$REMOTE/HEAD" 2>/dev/null \
        || git rev-parse "$REMOTE/main" 2>/dev/null \
        || echo "")
    if [ -n "$base" ]; then
      RANGE="${base}..${local_sha}"
    else
      RANGE="$local_sha"
    fi
  else
    RANGE="${remote_sha}..${local_sha}"
  fi

  # bypass via commit message token
  if git log "$RANGE" --pretty=%s 2>/dev/null \
       | grep -qiE '\[(skip-codex|wip)\]'; then
    echo "codex: skipped — [skip-codex] or [wip] found in commit range" >&2
    continue
  fi

  # cache: same local_sha already passed before
  CACHE="$GIT_DIR/codex-reviewed-$local_sha"
  if [ -f "$CACHE" ]; then
    echo "codex: already reviewed $local_sha, skipping" >&2
    continue
  fi

  # filter relevant files (.swift + *.md)
  RELEVANT=$(git diff --name-only "$RANGE" -- '*.swift' '*.md' 2>/dev/null)
  if [ -z "$RELEVANT" ]; then
    echo "codex: no .swift or .md changes, skipping" >&2
    touch "$CACHE"
    continue
  fi

  SWIFT_COUNT=$(printf '%s\n' "$RELEVANT" | grep -c '\.swift$' || true)
  MD_COUNT=$(printf '%s\n' "$RELEVANT" | grep -c '\.md$' || true)
  FILE_COUNT=$(printf '%s\n' "$RELEVANT" | sed '/^$/d' | wc -l | tr -d ' ')

  # docs-only diff: nothing code-related to review, skip to save cost
  if [ "$SWIFT_COUNT" -eq 0 ]; then
    echo "codex: docs-only change (${MD_COUNT} .md, 0 .swift), skipping" >&2
    touch "$CACHE"
    continue
  fi

  # codex binary check — missing is a warn, not a block
  if ! command -v codex >/dev/null 2>&1; then
    echo "codex: binary not found on PATH, allowing push (install: npm i -g @openai/codex)" >&2
    continue
  fi

  DIFF=$(git diff "$RANGE" -- '*.swift' '*.md')
  DIFF_LINES=$(printf '%s\n' "$DIFF" | wc -l | tr -d ' ')

  # safety cap on diff size
  if [ "$DIFF_LINES" -gt "$BIG_DIFF_LINES" ]; then
    echo "codex: diff too large ($DIFF_LINES lines > $BIG_DIFF_LINES), skipping auto-review" >&2
    echo "      split commits or bypass: git push --no-verify" >&2
    continue
  fi

  echo "codex: reviewing $FILE_COUNT file(s) [$SWIFT_COUNT swift, $MD_COUNT md], ~$DIFF_LINES lines (60-180s)..." >&2

  PROMPT=$(cat <<'PROMPT_EOF'
You are reviewing a git diff for the Glance project before it is pushed to the remote.

Glance (formerly ISeeImageViewer) is a native macOS SwiftUI local image viewer app (App Sandbox, Security-Scoped Bookmarks). No third-party libraries.

OUTPUT FORMAT (strict):
- Report ONLY issues. One per line, in the form:
    [P1|P2] <path>:<line-or-hunk> — <issue>
- If there are NO issues at all, output exactly: CLEAN
- Do not include headers, preambles, summaries, or praise.

============================================================
HARD RULES — [P1] (blocks push)
============================================================

Code (from CLAUDE.md):
1. No force unwrap `!`, `try!`, `as!` — exception: test targets with an inline comment justifying it.
2. No magic numbers — every literal used for a color, dimension, spacing, duration, or size must be a named constant. Colors must come from DS.*.
3. One public type per file. Nested private types are fine.
4. TODO must match format: `// TODO: [YYYY-MM-DD] description`. Any other TODO form is P1.
5. No third-party `import` statements — only Apple frameworks (SwiftUI, Foundation, AppKit, Combine, ImageIO, UniformTypeIdentifiers, etc.).
6. Async work must use async/await. Reject NEW Combine `.sink` or `@escaping` callback patterns introduced as an async mechanism. Delegate-based AppKit APIs (NSWindowDelegate, NSOpenPanel, NSViewRepresentable bridges) are OK.

UI (from specs/UI.md and CLAUDE.md):
7. All UI constants must reference `DS.*` (DesignSystem.swift). Reject hardcoded hex colors, `Color(red:...)`, spacing ints passed directly to `.padding()` / `.frame()` / `.spacing(...)`, or animation durations outside `DS.Anim.*`.
8. `.spring` animations are forbidden in viewer-family views. Use `DS.Anim.fast / normal / slow`.
9. Any view inside `QuickViewerOverlay` (including Filmstrip, TopBar, BottomToolbar, NavButtons) must use explicit dark-appropriate colors that read correctly under `.preferredColorScheme(.dark)`. System-material backgrounds (`.regularMaterial` etc.) that would flip under light mode are P1 here.
10. `ImagePreviewView` must use `Color.primary` for foreground. Hardcoded `.white` or `.black` is P1.

Doc sync (from CLAUDE.md "⚠️ 文档同步强制规则"):
11. If the diff modifies `.swift` AND the change falls into one of the categories below, the listed doc MUST also be modified in the SAME diff. If it is not, flag [P1] with message "missing doc sync — <which doc>":
    - Bug fix → `specs/Roadmap.md` Bug Fix 记录 has a new row (commit-hash placeholder is fine)
    - New / deleted / moved / renamed `.swift` file → `CLAUDE.md` 文件结构 updated
    - Module or sub-feature completion → `specs/<module>.md` 当前进度 updated
    - Architecture / interaction-logic change → `specs/Roadmap.md` 关键架构决策 updated
12. Use the commit messages (provided alongside the diff) to judge the category. A pure internal refactor with no user-visible, architectural, or file-structure change does NOT require a doc update — do not flag.
13. If you are uncertain whether a doc update is required, prefer [P2] over [P1].

============================================================
SOFT RULES — [P2] (warn, does not block)
============================================================
- Unclear / misleading names
- Missing tests for non-trivial new logic
- Comments that describe WHAT instead of WHY, or merely restate the code
- Private helpers introduced in this diff that have no caller

You will be given: (a) the commit messages in this push, (b) the diff restricted to `.swift` and `.md` files. Review both together.
PROMPT_EOF
)

  # payload for codex stdin: commit messages + diff
  PAYLOAD=$(printf '=== Commit messages in this push ===\n%s\n\n=== Diff ===\n%s\n' \
    "$(git log "$RANGE" --pretty='%h %s')" \
    "$DIFF")

  # run codex (stdin gets payload; prompt carries the rules)
  # `-o <file>` writes ONLY the agent's final message — avoids grepping the
  # prompt echoed in codex's startup log.
  REVIEW_FILE=$(mktemp -t codex-review.XXXXXX)
  STDERR_FILE=$(mktemp -t codex-stderr.XXXXXX)

  if ! printf '%s' "$PAYLOAD" | $TO \
      codex exec \
        -s read-only \
        --ephemeral \
        --color never \
        -o "$REVIEW_FILE" \
        -c 'model_reasoning_effort="high"' \
        "$PROMPT" >/dev/null 2>"$STDERR_FILE"; then
    ec=$?
    echo "codex: review failed (exit $ec), allowing push" >&2
    sed -n '1,15p' "$STDERR_FILE" >&2
    echo "      retry push, or bypass: git push --no-verify" >&2
    rm -f "$REVIEW_FILE" "$STDERR_FILE"
    continue
  fi

  REVIEW=$(cat "$REVIEW_FILE")
  rm -f "$REVIEW_FILE" "$STDERR_FILE"

  if [ -z "$REVIEW" ]; then
    echo "codex: empty review output, allowing push" >&2
    continue
  fi

  # verdict
  if printf '%s\n' "$REVIEW" | grep -q '\[P1\]'; then
    echo "" >&2
    echo "═════════ codex BLOCKED push — [P1] issues ═════════" >&2
    printf '%s\n' "$REVIEW" >&2
    echo "" >&2
    echo "Fix the issues above and push again." >&2
    echo "Bypass once (use sparingly): git push --no-verify" >&2
    exit 1
  fi

  if printf '%s\n' "$REVIEW" | grep -q '\[P2\]'; then
    echo "codex: no [P1]. [P2] warnings:" >&2
    printf '%s\n' "$REVIEW" | grep '\[P2\]' >&2
  else
    echo "codex: ✓ CLEAN ($local_sha)" >&2
  fi

  touch "$CACHE"
done

exit 0
